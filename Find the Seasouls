-- ==================== MEMBUAT TOMBOL FILTER ====================
local filterButtons = {}

local function clearFilterButtons()
    for _, btn in ipairs(filterButtons) do
        btn:Destroy()
    end
    table.clear(filterButtons)
end

local function buildFilterButtons()
    clearFilterButtons()
    local prefixes = {"All"}
    for _, pfx in ipairs(wantedPrefixes) do
        table.insert(prefixes, pfx)
    end

    for _, prefix in ipairs(prefixes) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 70, 1, 0)
        btn.BackgroundColor3 = currentFilter == prefix and Color3.fromRGB(10,132,255) or Color3.fromRGB(44,44,46)
        btn.BackgroundTransparency = 0.15
        btn.Text = prefix
        btn.TextColor3 = Color3.new(1,1,1)
        btn.Font = Enum.Font.GothamBold
        btn.TextSize = 11
        btn.BorderSizePixel = 0
        btn.Parent = filterScroll
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0,6)
        table.insert(filterButtons, btn)

        btn.MouseButton1Click:Connect(function()
            currentFilter = prefix
            buildFilterButtons()
            populate()
        end)
    end

    local totalWidth = 0
    for _, btn in ipairs(filterButtons) do
        totalWidth = totalWidth + btn.Size.X.Offset + 4
    end
    filterScroll.CanvasSize = UDim2.new(0, math.max(totalWidth, 1), 0, 0)
end

-- ==================== DRAG ====================
local dragging = false
local dragInput
local dragStart
local startPos

local function updateDrag(input)
    local delta = input.Position - dragStart
    Main.Position = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
end

TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = Main.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

TopBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UIS.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        updateDrag(input)
    end
end)

