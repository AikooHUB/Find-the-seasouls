-- ==================== FUNGSI UTAMA ====================
local currentTarget = "seasouls"
local stop = false
local autoTP = false
local stopTP = false
local currentFilter = "All"  -- "All" berarti Seasouls tanpa prefix event

-- Prefix event yang diketahui
local wantedPrefixes = {
    "Summer", "Halloween", "Canaryday", "Carnival", "Planetday", "Waterday", "Xmas"
}

-- Dapatkan posisi teleport dari objek
local function getPosition(obj)
    if obj:IsA("BasePart") then return obj.Position
    elseif obj:IsA("Model") then
        local pp = obj.PrimaryPart
        if pp then return pp.Position end
        local part = obj:FindFirstChildWhichIsA("BasePart")
        if part then return part.Position end
    end
    return nil
end

-- Ambil prefix (semua karakter non-digit di awal nama)
local function getPrefix(name)
    return string.match(name, "^(%D+)") or name
end

-- Cek apakah nama diawali salah satu prefix event
local function isEventSeasoul(name)
    local pfx = getPrefix(name)
    for _, event in ipairs(wantedPrefixes) do
        if pfx:lower() == event:lower() then
            return true
        end
    end
    return false
end

-- Ambil item sesuai target dan filter
local function getItems()
    local items = {}
    if currentTarget == "seasouls" and seasoulsFolder then
        for _, child in ipairs(seasoulsFolder:GetChildren()) do
            local name = child.Name
            local pos = getPosition(child)
            if not pos then continue end

            if currentFilter == "All" then
                -- Hanya Seasouls yang BUKAN event
                if not isEventSeasoul(name) then
                    table.insert(items, {Name = name, Position = pos + Vector3.new(0, 5, 0)})
                end
            else
                -- Hanya Seasouls dengan prefix yang sesuai
                local prefix = getPrefix(name)
                if prefix:lower() == currentFilter:lower() then
                    table.insert(items, {Name = name, Position = pos + Vector3.new(0, 5, 0)})
                end
            end
        end
        table.sort(items, function(a,b) return a.Name < b.Name end)
    elseif currentTarget == "shell" and conchasFolder then
        for _, child in ipairs(conchasFolder:GetChildren()) do
            local name = child.Name
            if name:match("^Shell") then
                local pos = getPosition(child)
                if pos then
                    table.insert(items, {Name = name, Position = pos + Vector3.new(0, 5, 0)})
                end
            end
        end
        table.sort(items, function(a,b) return a.Name < b.Name end)
    end
    return items
end

-- Teleport semua item
local function teleportAll()
    local items = getItems()
    if #items == 0 then return end
    local delayTime = (currentTarget == "seasouls") and 1.5 or 0.8
    for _, item in ipairs(items) do
        if stopTP or stop then break end
        local char = p.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = CFrame.new(item.Position)
        end
        task.wait(delayTime)
    end
end

-- Loop Auto TP
local function autoTPLoop()
    while autoTP and not stop do
        teleportAll()
        task.wait(1)
    end
end

