-- ==================== FUNGSI TELEPORT ====================
local function getItemPosition(obj)
    if obj:IsA("BasePart") then
        return obj.Position
    elseif obj:IsA("Model") then
        local pp = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        if pp then return pp.Position end
    elseif obj:IsA("Folder") then
        for _, child in ipairs(obj:GetDescendants()) do
            if child:IsA("BasePart") then return child.Position end
        end
    end
    return nil
end

local function hasProximityPrompt(obj)
    for _, child in ipairs(obj:GetDescendants()) do
        if child:IsA("ProximityPrompt") then
            return true
        end
    end
    return false
end

local function teleportToItem(item)
    local pos = getItemPosition(item)
    if pos then
        local char = Player.Character
        if char and char:FindFirstChild("HumanoidRootPart") then
            char.HumanoidRootPart.CFrame = CFrame.new(pos + Vector3.new(0, 5, 0))
        end
    end
end

local function teleportToPlayer(targetPlayer)
    local char = targetPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        local pos = char.HumanoidRootPart.Position
        local myChar = Player.Character
        if myChar and myChar:FindFirstChild("HumanoidRootPart") then
            myChar.HumanoidRootPart.CFrame = CFrame.new(pos + Vector3.new(0, 5, 0))
        end
    end
end

-- ==================== DAFTAR ITEM TARGET ====================
local targetNames = {
    "Apple", "Axe", "Bucket", "FishLarge", "FishMedium", "Fish small", "Plank", "Repair hammer", "RepairHammer"
}

local function collectInteractiveItems()
    local items = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local name = obj.Name
        for _, target in ipairs(targetNames) do
            if name == target and (obj:IsA("BasePart") or obj:IsA("Model") or obj:IsA("Folder")) then
                if hasProximityPrompt(obj) then
                    local pos = getItemPosition(obj)
                    if pos then
                        table.insert(items, {Name = name, Obj = obj, Position = pos})
                    end
                end
                break
            end
        end
    end
    -- Urutkan sesuai targetNames
    local sorted = {}
    for _, target in ipairs(targetNames) do
        for _, item in ipairs(items) do
            if item.Name == target then
                table.insert(sorted, item)
            end
        end
    end
    return sorted
end

